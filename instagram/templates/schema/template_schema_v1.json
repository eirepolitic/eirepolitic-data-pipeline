{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eirepolitic.local/instagram/template_schema_v1.json",
  "title": "Eirepolitic Instagram Template Schema v1",
  "type": "object",
  "required": ["schema_version", "template_id", "width", "height", "palette", "elements"],
  "properties": {
    "schema_version": {"type": "string"},
    "template_id": {"type": "string"},
    "description": {"type": "string"},
    "width": {"type": "integer", "minimum": 1},
    "height": {"type": "integer", "minimum": 1},
    "palette": {"type": "string"},
    "background": {"type": "object"},
    "elements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "x", "y", "w", "h"],
        "properties": {
          "id": {"type": "string"},
          "type": {"enum": ["text", "image", "rectangle", "line", "group"]},
          "placeholder": {"type": "string"},
          "x": {"type": "integer"},
          "y": {"type": "integer"},
          "w": {"type": "integer", "minimum": 0},
          "h": {"type": "integer", "minimum": 0},
          "fit": {"enum": ["cover", "contain", "stretch"]},
          "radius": {"type": "integer", "minimum": 0},
          "fill": {"type": "string"},
          "outline": {"type": "string"},
          "width": {"type": "integer", "minimum": 0},
          "style": {"type": "object"},
          "children": {"type": "array"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
