{
  "schema_version": "1.0",
  "template_id": "title_two_visuals_v1",
  "description": "Title-above-two-visuals post layout. No built-in corner decorations; standard corner overlay is applied after render.",
  "width": 1080,
  "height": 1350,
  "palette": "eirepolitic_dark",
  "background": {
    "type": "solid",
    "color": "{palette.panel_background}"
  },
  "elements": [
    {
      "id": "title",
      "type": "text",
      "placeholder": "slide_title",
      "x": 80,
      "y": 95,
      "w": 920,
      "h": 130,
      "style": {
        "font_family": "default_bold",
        "font_size": 62,
        "min_font_size": 34,
        "color": "{palette.text_primary}",
        "align": "center",
        "valign": "middle",
        "max_lines": 2,
        "shrink_to_fit": true,
        "line_spacing": 8
      }
    },
    {
      "id": "main_panel",
      "type": "rectangle",
      "x": 80,
      "y": 245,
      "w": 920,
      "h": 1010,
      "radius": 0,
      "fill": "{palette.panel_background_alt}",
      "stroke": null,
      "width": 0
    },
    {
      "id": "visual_1",
      "type": "image",
      "placeholder": "visual_1",
      "x": 120,
      "y": 305,
      "w": 840,
      "h": 390,
      "fit": "contain",
      "radius": 0,
      "background": "{palette.panel_background}"
    },
    {
      "id": "visual_1_caption",
      "type": "text",
      "placeholder": "visual_1_caption",
      "x": 135,
      "y": 710,
      "w": 810,
      "h": 80,
      "style": {
        "font_family": "default_bold",
        "font_size": 34,
        "min_font_size": 22,
        "color": "{palette.text_primary}",
        "align": "center",
        "valign": "middle",
        "max_lines": 2,
        "shrink_to_fit": true,
        "line_spacing": 6
      }
    },
    {
      "id": "divider",
      "type": "line",
      "x": 160,
      "y": 820,
      "w": 760,
      "h": 0,
      "fill": "{palette.border}",
      "width": 4
    },
    {
      "id": "visual_2",
      "type": "image",
      "placeholder": "visual_2",
      "x": 120,
      "y": 860,
      "w": 840,
      "h": 300,
      "fit": "contain",
      "radius": 0,
      "background": "{palette.panel_background}"
    },
    {
      "id": "visual_2_caption",
      "type": "text",
      "placeholder": "visual_2_caption",
      "x": 135,
      "y": 1175,
      "w": 810,
      "h": 55,
      "style": {
        "font_family": "default_bold",
        "font_size": 30,
        "min_font_size": 20,
        "color": "{palette.text_primary}",
        "align": "center",
        "valign": "middle",
        "max_lines": 2,
        "shrink_to_fit": true,
        "line_spacing": 5
      }
    }
  ]
}
