{
  "schema_version": "1.0",
  "template_id": "profile_card_v1",
  "description": "Single TD profile card for member_profile_batch_v1",
  "width": 1080,
  "height": 1350,
  "palette": "eirepolitic_dark",
  "background": {
    "type": "solid",
    "color": "{palette.background}"
  },
  "elements": [
    {
      "id": "card_bg",
      "type": "rectangle",
      "x": 56,
      "y": 56,
      "w": 968,
      "h": 1238,
      "radius": 36,
      "fill": "{palette.panel_background}",
      "stroke": "{palette.border}"
    },
    {
      "id": "member_photo",
      "type": "image",
      "placeholder": "member_photo",
      "x": 80,
      "y": 92,
      "w": 380,
      "h": 460,
      "fit": "cover",
      "radius": 28,
      "background": "{palette.panel_background_alt}"
    },
    {
      "id": "member_name",
      "type": "text",
      "placeholder": "member_name",
      "x": 490,
      "y": 110,
      "w": 460,
      "h": 150,
      "style": {
        "font_family": "default_bold",
        "font_size": 58,
        "color": "{palette.text_primary}",
        "align": "left",
        "valign": "top",
        "max_lines": 2,
        "shrink_to_fit": true
      }
    },
    {
      "id": "party",
      "type": "text",
      "placeholder": "party",
      "x": 492,
      "y": 280,
      "w": 430,
      "h": 46,
      "style": {
        "font_size": 30,
        "color": "{palette.accent}",
        "align": "left",
        "max_lines": 1,
        "shrink_to_fit": true
      }
    },
    {
      "id": "constituency",
      "type": "text",
      "placeholder": "constituency",
      "x": 492,
      "y": 340,
      "w": 430,
      "h": 78,
      "style": {
        "font_size": 30,
        "color": "{palette.text_muted}",
        "align": "left",
        "max_lines": 2,
        "shrink_to_fit": true
      }
    },
    {
      "id": "metrics_panel",
      "type": "rectangle",
      "x": 80,
      "y": 600,
      "w": 920,
      "h": 470,
      "radius": 28,
      "fill": "{palette.panel_background_alt}"
    },
    {
      "id": "top_issue_label",
      "type": "text",
      "text": "Top issue in 2025 debate speeches",
      "x": 112,
      "y": 632,
      "w": 850,
      "h": 42,
      "style": {
        "font_size": 28,
        "color": "{palette.text_muted}",
        "align": "left",
        "max_lines": 1
      }
    },
    {
      "id": "top_issue",
      "type": "text",
      "placeholder": "top_issue",
      "x": 112,
      "y": 686,
      "w": 850,
      "h": 90,
      "style": {
        "font_family": "default_bold",
        "font_size": 48,
        "color": "{palette.text_primary}",
        "align": "left",
        "max_lines": 2,
        "shrink_to_fit": true
      }
    },
    {
      "id": "vote_label",
      "type": "text",
      "text": "Vote participation",
      "x": 112,
      "y": 818,
      "w": 370,
      "h": 36,
      "style": {
        "font_size": 26,
        "color": "{palette.text_muted}",
        "align": "left"
      }
    },
    {
      "id": "vote_participation",
      "type": "text",
      "placeholder": "vote_participation",
      "x": 112,
      "y": 862,
      "w": 370,
      "h": 76,
      "style": {
        "font_family": "default_bold",
        "font_size": 56,
        "color": "{palette.text_primary}",
        "align": "left",
        "max_lines": 1,
        "shrink_to_fit": true
      }
    },
    {
      "id": "speech_label",
      "type": "text",
      "text": "Speech rank",
      "x": 570,
      "y": 818,
      "w": 360,
      "h": 36,
      "style": {
        "font_size": 26,
        "color": "{palette.text_muted}",
        "align": "left"
      }
    },
    {
      "id": "speech_rank",
      "type": "text",
      "placeholder": "speech_rank",
      "x": 570,
      "y": 862,
      "w": 360,
      "h": 76,
      "style": {
        "font_family": "default_bold",
        "font_size": 56,
        "color": "{palette.text_primary}",
        "align": "left",
        "max_lines": 1,
        "shrink_to_fit": true
      }
    },
    {
      "id": "speech_count",
      "type": "text",
      "placeholder": "speech_count_text",
      "x": 112,
      "y": 978,
      "w": 820,
      "h": 42,
      "style": {
        "font_size": 28,
        "color": "{palette.text_muted}",
        "align": "left",
        "max_lines": 1,
        "shrink_to_fit": true
      }
    },
    {
      "id": "footer",
      "type": "text",
      "placeholder": "footer_text",
      "x": 90,
      "y": 1215,
      "w": 900,
      "h": 56,
      "style": {
        "font_size": 24,
        "color": "{palette.text_muted}",
        "align": "center",
        "valign": "middle",
        "max_lines": 2,
        "shrink_to_fit": true
      }
    }
  ]
}
