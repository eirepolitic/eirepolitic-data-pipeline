{
  "schema_version": "1.0",
  "template_id": "profile_card_v1",
  "description": "Single-member profile card for deterministic Instagram member-profile campaign posts.",
  "width": 1080,
  "height": 1350,
  "palette": "eirepolitic_dark",
  "background": {
    "type": "solid",
    "color": "{palette.background}"
  },
  "elements": [
    {
      "id": "top_band",
      "type": "rectangle",
      "x": 56,
      "y": 56,
      "w": 968,
      "h": 1238,
      "radius": 42,
      "fill": "{palette.panel_background}",
      "outline": "{palette.border}",
      "width": 3
    },
    {
      "id": "eyebrow",
      "type": "text",
      "placeholder": "eyebrow",
      "x": 92,
      "y": 92,
      "w": 896,
      "h": 42,
      "style": {
        "font_family": "default_bold",
        "font_size": 26,
        "color": "{palette.accent}",
        "align": "center",
        "valign": "middle",
        "max_lines": 1
      }
    },
    {
      "id": "member_photo_panel",
      "type": "rectangle",
      "x": 92,
      "y": 166,
      "w": 372,
      "h": 462,
      "radius": 30,
      "fill": "{palette.panel_background_alt}",
      "outline": "{palette.border}",
      "width": 2
    },
    {
      "id": "member_photo",
      "type": "image",
      "placeholder": "member_photo",
      "x": 110,
      "y": 184,
      "w": 336,
      "h": 426,
      "fit": "cover",
      "radius": 24
    },
    {
      "id": "member_name",
      "type": "text",
      "placeholder": "member_name",
      "x": 500,
      "y": 176,
      "w": 470,
      "h": 150,
      "style": {
        "font_family": "default_bold",
        "font_size": 58,
        "color": "{palette.text_primary}",
        "align": "left",
        "valign": "top",
        "max_lines": 2,
        "shrink_to_fit": true
      }
    },
    {
      "id": "party_constituency",
      "type": "text",
      "placeholder": "party_constituency",
      "x": 502,
      "y": 344,
      "w": 470,
      "h": 92,
      "style": {
        "font_size": 30,
        "color": "{palette.text_muted}",
        "align": "left",
        "valign": "top",
        "max_lines": 2
      }
    },
    {
      "id": "metric_top_issue_label",
      "type": "text",
      "placeholder": "top_issue_label",
      "x": 500,
      "y": 478,
      "w": 468,
      "h": 34,
      "style": {
        "font_family": "default_bold",
        "font_size": 24,
        "color": "{palette.accent}",
        "align": "left",
        "max_lines": 1
      }
    },
    {
      "id": "top_issue",
      "type": "text",
      "placeholder": "top_issue",
      "x": 500,
      "y": 520,
      "w": 468,
      "h": 102,
      "style": {
        "font_family": "default_bold",
        "font_size": 42,
        "color": "{palette.text_primary}",
        "align": "left",
        "max_lines": 2,
        "shrink_to_fit": true
      }
    },
    {
      "id": "metrics_panel",
      "type": "rectangle",
      "x": 92,
      "y": 670,
      "w": 896,
      "h": 318,
      "radius": 30,
      "fill": "{palette.panel_background_alt}",
      "outline": "{palette.border}",
      "width": 2
    },
    {
      "id": "vote_label",
      "type": "text",
      "placeholder": "vote_label",
      "x": 134,
      "y": 708,
      "w": 400,
      "h": 34,
      "style": {"font_family": "default_bold", "font_size": 24, "color": "{palette.accent}", "align": "left"}
    },
    {
      "id": "vote_participation",
      "type": "text",
      "placeholder": "vote_participation",
      "x": 134,
      "y": 752,
      "w": 360,
      "h": 74,
      "style": {"font_family": "default_bold", "font_size": 56, "color": "{palette.text_primary}", "align": "left", "max_lines": 1, "shrink_to_fit": true}
    },
    {
      "id": "speech_label",
      "type": "text",
      "placeholder": "speech_label",
      "x": 556,
      "y": 708,
      "w": 390,
      "h": 34,
      "style": {"font_family": "default_bold", "font_size": 24, "color": "{palette.accent}", "align": "left"}
    },
    {
      "id": "speech_rank",
      "type": "text",
      "placeholder": "speech_rank",
      "x": 556,
      "y": 752,
      "w": 380,
      "h": 74,
      "style": {"font_family": "default_bold", "font_size": 56, "color": "{palette.text_primary}", "align": "left", "max_lines": 1, "shrink_to_fit": true}
    },
    {
      "id": "speech_count_label",
      "type": "text",
      "placeholder": "speech_count_label",
      "x": 134,
      "y": 868,
      "w": 812,
      "h": 40,
      "style": {"font_size": 26, "color": "{palette.text_muted}", "align": "left", "max_lines": 1}
    },
    {
      "id": "background",
      "type": "text",
      "placeholder": "background",
      "x": 92,
      "y": 1034,
      "w": 896,
      "h": 130,
      "style": {
        "font_size": 28,
        "color": "{palette.text_primary}",
        "align": "left",
        "valign": "top",
        "max_lines": 4,
        "shrink_to_fit": true
      }
    },
    {
      "id": "footer",
      "type": "text",
      "placeholder": "footer_text",
      "x": 92,
      "y": 1224,
      "w": 896,
      "h": 46,
      "style": {
        "font_size": 22,
        "color": "{palette.text_muted}",
        "align": "center",
        "valign": "middle",
        "max_lines": 1
      }
    }
  ]
}
