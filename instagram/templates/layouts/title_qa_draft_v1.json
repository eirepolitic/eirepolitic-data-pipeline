{
  "schema_version": "1.0",
  "template_id": "title_qa_draft_v1",
  "description": "Draft title-above-question-answer post layout. No built-in corner decorations; standard corner overlay is applied after render.",
  "width": 1080,
  "height": 1350,
  "palette": "eirepolitic_dark",
  "background": {
    "type": "solid",
    "color": "{palette.panel_background}"
  },
  "elements": [
    {
      "id": "title",
      "type": "text",
      "placeholder": "slide_title",
      "x": 80,
      "y": 95,
      "w": 920,
      "h": 130,
      "style": {
        "font_family": "default_bold",
        "font_size": 62,
        "min_font_size": 34,
        "color": "{palette.text_primary}",
        "align": "center",
        "valign": "middle",
        "max_lines": 2,
        "shrink_to_fit": true,
        "line_spacing": 8
      }
    },
    {
      "id": "qa_panel",
      "type": "rectangle",
      "x": 80,
      "y": 245,
      "w": 920,
      "h": 1010,
      "radius": 0,
      "fill": "{palette.panel_background_alt}",
      "stroke": null,
      "width": 0
    },
    {
      "id": "question_label",
      "type": "text",
      "text": "QUESTION",
      "x": 135,
      "y": 315,
      "w": 810,
      "h": 42,
      "style": {
        "font_family": "default_bold",
        "font_size": 28,
        "min_font_size": 20,
        "color": "{palette.text_muted}",
        "align": "center",
        "valign": "middle",
        "max_lines": 1,
        "shrink_to_fit": true
      }
    },
    {
      "id": "question_text",
      "type": "text",
      "placeholder": "question_text",
      "x": 135,
      "y": 380,
      "w": 810,
      "h": 220,
      "style": {
        "font_family": "default_bold",
        "font_size": 54,
        "min_font_size": 32,
        "color": "{palette.text_primary}",
        "align": "center",
        "valign": "middle",
        "max_lines": 4,
        "shrink_to_fit": true,
        "line_spacing": 10
      }
    },
    {
      "id": "qa_rule",
      "type": "line",
      "x": 210,
      "y": 660,
      "w": 660,
      "h": 0,
      "fill": "{palette.border}",
      "width": 5
    },
    {
      "id": "answer_label",
      "type": "text",
      "text": "ANSWER",
      "x": 135,
      "y": 705,
      "w": 810,
      "h": 42,
      "style": {
        "font_family": "default_bold",
        "font_size": 28,
        "min_font_size": 20,
        "color": "{palette.text_muted}",
        "align": "center",
        "valign": "middle",
        "max_lines": 1,
        "shrink_to_fit": true
      }
    },
    {
      "id": "answer_text",
      "type": "text",
      "placeholder": "answer_text",
      "x": 145,
      "y": 775,
      "w": 790,
      "h": 315,
      "style": {
        "font_size": 38,
        "min_font_size": 25,
        "color": "{palette.text_primary}",
        "align": "center",
        "valign": "top",
        "max_lines": 7,
        "shrink_to_fit": true,
        "line_spacing": 13
      }
    },
    {
      "id": "bottom_note",
      "type": "text",
      "placeholder": "bottom_note",
      "x": 145,
      "y": 1150,
      "w": 790,
      "h": 70,
      "style": {
        "font_size": 26,
        "min_font_size": 19,
        "color": "{palette.text_primary}",
        "align": "center",
        "valign": "middle",
        "max_lines": 2,
        "shrink_to_fit": true,
        "line_spacing": 5
      }
    }
  ]
}
