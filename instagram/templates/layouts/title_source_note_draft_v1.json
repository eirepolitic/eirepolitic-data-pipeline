{
  "schema_version": "1.0",
  "template_id": "title_source_note_draft_v1",
  "description": "Draft title-above-source-note post layout. No built-in corner decorations; standard corner overlay is applied after render.",
  "width": 1080,
  "height": 1350,
  "palette": "eirepolitic_dark",
  "background": {
    "type": "solid",
    "color": "{palette.panel_background}"
  },
  "elements": [
    {
      "id": "title",
      "type": "text",
      "placeholder": "slide_title",
      "x": 80,
      "y": 95,
      "w": 920,
      "h": 130,
      "style": {
        "font_family": "default_bold",
        "font_size": 62,
        "min_font_size": 34,
        "color": "{palette.text_primary}",
        "align": "center",
        "valign": "middle",
        "max_lines": 2,
        "shrink_to_fit": true,
        "line_spacing": 8
      }
    },
    {
      "id": "source_panel",
      "type": "rectangle",
      "x": 80,
      "y": 245,
      "w": 920,
      "h": 1010,
      "radius": 0,
      "fill": "{palette.panel_background_alt}",
      "stroke": null,
      "width": 0
    },
    {
      "id": "main_statement",
      "type": "text",
      "placeholder": "main_statement",
      "x": 135,
      "y": 330,
      "w": 810,
      "h": 220,
      "style": {
        "font_family": "default_bold",
        "font_size": 54,
        "min_font_size": 32,
        "color": "{palette.text_primary}",
        "align": "center",
        "valign": "middle",
        "max_lines": 4,
        "shrink_to_fit": true,
        "line_spacing": 10
      }
    },
    {
      "id": "statement_rule",
      "type": "line",
      "x": 210,
      "y": 600,
      "w": 660,
      "h": 0,
      "fill": "{palette.border}",
      "width": 5
    },
    {
      "id": "body_text",
      "type": "text",
      "placeholder": "body_text",
      "x": 145,
      "y": 650,
      "w": 790,
      "h": 260,
      "style": {
        "font_size": 36,
        "min_font_size": 24,
        "color": "{palette.text_primary}",
        "align": "center",
        "valign": "top",
        "max_lines": 6,
        "shrink_to_fit": true,
        "line_spacing": 12
      }
    },
    {
      "id": "source_box",
      "type": "rectangle",
