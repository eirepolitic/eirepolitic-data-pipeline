      "y": 965,
      "w": 840,
      "h": 210,
      "radius": 0,
      "fill": "{palette.panel_background}",
      "stroke": "{palette.border}",
      "width": 4
    },
    {
      "id": "source_label",
      "type": "text",
      "text": "SOURCE / METHOD",
      "x": 155,
      "y": 995,
      "w": 770,
      "h": 36,
      "style": {
        "font_family": "default_bold",
        "font_size": 25,
        "min_font_size": 18,
        "color": "{palette.text_muted}",
        "align": "center",
        "valign": "middle",
        "max_lines": 1,
        "shrink_to_fit": true
      }
    },
    {
      "id": "source_text",
      "type": "text",
      "placeholder": "source_text",
      "x": 155,
      "y": 1045,
      "w": 770,
      "h": 100,
      "style": {
        "font_size": 27,
        "min_font_size": 18,
        "color": "{palette.text_primary}",
        "align": "center",
        "valign": "middle",
        "max_lines": 3,
        "shrink_to_fit": true,
        "line_spacing": 6
      }
    },
    {
      "id": "bottom_note",
      "type": "text",
      "placeholder": "bottom_note",
      "x": 145,
      "y": 1190,
      "w": 790,
      "h": 45,
      "style": {
        "font_size": 23,
        "min_font_size": 17,
        "color": "{palette.text_primary}",
        "align": "center",
        "valign": "middle",
        "max_lines": 2,
        "shrink_to_fit": true,
        "line_spacing": 4
      }
    }
  ]
}
