{
  "schema_version": "1.0",
  "template_id": "title_split_visual_text_v1",
  "description": "Title-above-visual-and-text post layout. No built-in corner decorations; standard corner overlay is applied after render.",
  "width": 1080,
  "height": 1350,
  "palette": "eirepolitic_dark",
  "background": {
    "type": "solid",
    "color": "{palette.panel_background}"
  },
  "elements": [
    {
      "id": "title",
      "type": "text",
      "placeholder": "slide_title",
      "x": 80,
      "y": 95,
      "w": 920,
      "h": 130,
      "style": {
        "font_family": "default_bold",
        "font_size": 62,
        "min_font_size": 34,
        "color": "{palette.text_primary}",
        "align": "center",
        "valign": "middle",
        "max_lines": 2,
        "shrink_to_fit": true,
        "line_spacing": 8
      }
    },
    {
      "id": "main_panel",
      "type": "rectangle",
      "x": 80,
      "y": 245,
      "w": 920,
      "h": 1010,
      "radius": 0,
      "fill": "{palette.panel_background_alt}",
      "stroke": null,
      "width": 0
    },
    {
      "id": "main_visual",
      "type": "image",
      "placeholder": "main_visual",
      "x": 120,
      "y": 285,
      "w": 840,
      "h": 555,
      "fit": "contain",
      "radius": 0,
      "background": "{palette.panel_background}"
    },
    {
      "id": "split_rule",
      "type": "line",
      "x": 160,
      "y": 885,
      "w": 760,
      "h": 0,
      "fill": "{palette.border}",
      "width": 4
    },
    {
      "id": "body_text",
      "type": "text",
      "placeholder": "body_text",
      "x": 135,
      "y": 925,
      "w": 810,
      "h": 250,
      "style": {
        "font_size": 36,
        "min_font_size": 24,
        "color": "{palette.text_primary}",
        "align": "center",
        "valign": "top",
        "max_lines": 6,
        "shrink_to_fit": true,
        "line_spacing": 12
      }
    }
  ]
}
