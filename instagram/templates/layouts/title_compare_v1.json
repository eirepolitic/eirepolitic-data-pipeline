      "id": "title",
      "type": "text",
      "placeholder": "slide_title",
      "x": 80,
      "y": 95,
      "w": 920,
      "h": 130,
      "style": {
        "font_family": "default_bold",
        "font_size": 62,
        "min_font_size": 34,
