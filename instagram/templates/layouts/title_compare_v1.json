{
  "schema_version": "1.0",
  "template_id": "title_compare_v1",
  "description": "Title-above-two-column comparison post layout. No built-in corner decorations; standard corner overlay is applied after render.",
  "width": 1080,
  "height": 1350,
  "palette": "eirepolitic_dark",
  "background": {
    "type": "solid",
    "color": "{palette.panel_background}"
  },
