{
  "schema_version": "1.0",
  "template_id": "title_text_v1",
  "description": "Simple title-above-text post layout. No built-in corner decorations; standard corner overlay is applied after render.",
  "width": 1080,
  "height": 1350,
  "palette": "eirepolitic_dark",
  "background": {
    "type": "solid",
    "color": "{palette.panel_background}"
  },
  "elements": [
    {
      "id": "title",
      "type": "text",
      "placeholder": "slide_title",
      "x": 80,
      "y": 95,
      "w": 920,
      "h": 130,
      "style": {
        "font_family": "default_bold",
        "font_size": 62,
        "min_font_size": 34,
        "color": "{palette.text_primary}",
        "align": "center",
        "valign": "middle",
        "max_lines": 2,
        "shrink_to_fit": true,
        "line_spacing": 8
      }
    },
    {
      "id": "body_text_panel",
      "type": "rectangle",
      "x": 80,
      "y": 245,
      "w": 920,
      "h": 1010,
      "radius": 0,
      "fill": "{palette.panel_background_alt}",
      "stroke": null,
      "width": 0
    },
    {
      "id": "body_text",
      "type": "text",
      "placeholder": "body_text",
      "x": 130,
      "y": 305,
      "w": 820,
      "h": 890,
      "style": {
        "font_size": 44,
        "min_font_size": 28,
        "color": "{palette.text_primary}",
        "align": "left",
        "valign": "top",
        "max_lines": 14,
        "shrink_to_fit": true,
        "line_spacing": 18
      }
    }
  ]
}
