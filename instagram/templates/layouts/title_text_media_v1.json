{
  "schema_version": "1.0",
  "template_id": "title_text_media_v1",
  "description": "Title, short explanatory text, and media block",
  "width": 1080,
  "height": 1350,
  "palette": "eirepolitic_dark",
  "background": {"type": "solid", "color": "{palette.background}"},
  "elements": [
    {"id": "title", "type": "text", "placeholder": "slide_title", "x": 76, "y": 72, "w": 928, "h": 110, "style": {"font_family": "default_bold", "font_size": 54, "color": "{palette.text_primary}", "align": "left", "max_lines": 2, "shrink_to_fit": true}},
    {"id": "body", "type": "text", "placeholder": "body_text", "x": 76, "y": 200, "w": 928, "h": 170, "style": {"font_size": 30, "color": "{palette.text_muted}", "align": "left", "max_lines": 4, "shrink_to_fit": true}},
    {"id": "main_media", "type": "image", "placeholder": "main_media", "x": 76, "y": 410, "w": 928, "h": 760, "fit": "contain", "background": "{palette.panel_background}", "radius": 28},
    {"id": "footer", "type": "text", "placeholder": "footer_text", "x": 76, "y": 1222, "w": 928, "h": 56, "style": {"font_size": 24, "color": "{palette.text_muted}", "align": "center", "valign": "middle", "max_lines": 2}}
  ]
}
