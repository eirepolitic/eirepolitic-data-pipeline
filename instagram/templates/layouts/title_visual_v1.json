{
  "schema_version": "1.0",
  "template_id": "title_visual_v1",
  "description": "Simple title-above-visual post layout. No built-in corner decorations; standard corner overlay is applied after render.",
  "width": 1080,
  "height": 1350,
  "palette": "eirepolitic_dark",
  "background": {
    "type": "solid",
    "color": "{palette.panel_background}"
  },
  "elements": [
    {
      "id": "title",
      "type": "text",
      "placeholder": "slide_title",
      "x": 80,
      "y": 95,
      "w": 920,
      "h": 130,
      "style": {
        "font_family": "default_bold",
        "font_size": 62,
        "min_font_size": 34,
        "color": "{palette.text_primary}",
        "align": "center",
        "valign": "middle",
        "max_lines": 2,
        "shrink_to_fit": true,
        "line_spacing": 8
      }
    },
    {
      "id": "main_visual",
      "type": "image",
      "placeholder": "main_visual",
      "x": 80,
      "y": 245,
      "w": 920,
      "h": 1010,
      "fit": "contain",
      "radius": 0,
      "background": "{palette.panel_background_alt}"
    }
  ]
}
