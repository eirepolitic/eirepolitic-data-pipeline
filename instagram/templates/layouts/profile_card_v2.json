{
  "schema_version": "1.0",
  "template_id": "profile_card_v2",
  "description": "Centered TD profile card stress-test layout for member_profile_batch_v1",
  "width": 1080,
  "height": 1350,
  "palette": "eirepolitic_dark",
  "background": {
    "type": "solid",
    "color": "{palette.background}"
  },
  "elements": [
    {
      "id": "card_bg",
      "type": "rectangle",
      "x": 56,
      "y": 56,
      "w": 968,
      "h": 1238,
      "radius": 36,
      "fill": "{palette.panel_background}",
      "stroke": "{palette.border}"
    },
    {
      "id": "member_photo",
      "type": "image",
      "placeholder": "member_photo",
      "x": 290,
      "y": 92,
      "w": 500,
      "h": 520,
      "fit": "cover",
      "radius": 32,
      "background": "{palette.panel_background_alt}"
    },
    {
      "id": "member_name",
      "type": "text",
      "placeholder": "member_name",
      "x": 100,
      "y": 636,
      "w": 880,
      "h": 118,
      "style": {
        "font_family": "default_bold",
        "font_size": 58,
        "min_font_size": 34,
        "color": "{palette.text_primary}",
        "align": "center",
        "valign": "middle",
        "max_lines": 2,
        "shrink_to_fit": true,
        "line_spacing": 8
      }
    },
    {
      "id": "constituency",
      "type": "text",
      "placeholder": "constituency",
      "x": 100,
      "y": 772,
      "w": 420,
      "h": 78,
