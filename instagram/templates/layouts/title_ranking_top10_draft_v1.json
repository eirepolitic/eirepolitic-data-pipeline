{
  "schema_version": "1.0",
  "template_id": "title_ranking_top10_draft_v1",
  "description": "Draft title-above-top-10 ranked-list post layout. No built-in corner decorations; standard corner overlay is applied after render.",
  "width": 1080,
  "height": 1350,
  "palette": "eirepolitic_dark",
  "background": {
    "type": "solid",
    "color": "{palette.panel_background}"
  },
  "elements": [
    {
      "id": "title",
      "type": "text",
      "placeholder": "slide_title",
      "x": 80,
      "y": 95,
      "w": 920,
      "h": 130,
      "style": {
        "font_family": "default_bold",
        "font_size": 62,
        "min_font_size": 34,
        "color": "{palette.text_primary}",
        "align": "center",
        "valign": "middle",
        "max_lines": 2,
        "shrink_to_fit": true,
        "line_spacing": 8
      }
    },
    {
      "id": "ranking_panel",
      "type": "rectangle",
      "x": 80,
      "y": 245,
      "w": 920,
      "h": 1010,
      "radius": 0,
      "fill": "{palette.panel_background_alt}",
      "stroke": null,
      "width": 0
    },
    {
      "id": "ranking_intro",
      "type": "text",
      "placeholder": "ranking_intro",
      "x": 135,
      "y": 295,
      "w": 810,
      "h": 70,
      "style": {
        "font_size": 30,
        "min_font_size": 22,
        "color": "{palette.text_primary}",
        "align": "center",
        "valign": "middle",
        "max_lines": 2,
        "shrink_to_fit": true,
        "line_spacing": 6
      }
    },
    {
      "id": "ranking_text",
      "type": "text",
      "placeholder": "ranking_text",
      "x": 140,
      "y": 395,
      "w": 800,
      "h": 760,
      "style": {
        "font_family": "default_bold",
        "font_size": 35,
        "min_font_size": 24,
        "color": "{palette.text_primary}",
        "align": "left",
        "valign": "top",
        "max_lines": 10,
        "shrink_to_fit": true,
        "line_spacing": 14
      }
    },
    {
      "id": "bottom_note",
      "type": "text",
      "placeholder": "bottom_note",
      "x": 145,
      "y": 1180,
      "w": 790,
      "h": 55,
      "style": {
        "font_size": 24,
        "min_font_size": 18,
        "color": "{palette.text_primary}",
        "align": "center",
        "valign": "middle",
        "max_lines": 2,
        "shrink_to_fit": true,
        "line_spacing": 5
      }
    }
  ]
}
