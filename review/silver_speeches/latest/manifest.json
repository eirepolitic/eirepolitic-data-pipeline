htas/member/id/Carol-Nolan.D.2016-10-03","member_code":"Carol-Nolan.D.2016-10-03","show_as":"Carol Nolan"},{"e_id":"CathalCrowe","href":"/ie/oireachtas/member/id/Cathal-Crowe.D.2020-02-08","member_code":"Cathal-Crowe.D.2020-02-08","show_as":"Cathal Crowe"},{"e_id":"CatherineArdagh","href":"/ie/oireachtas/member/id/Catherine-Ardagh.S.2016-04-25","member_code":"Catherine-Ardagh.S.2016-04-25","show_as":"Catherine Ardagh"},{"e_id":"CatherineCallaghan","href":"/ie/oireachtas/member/id/Catherine-Callaghan.D.2024-11-29","member_code":"Catherine-Callaghan.D.2024-11-29","show_as":"Catherine Callaghan"},{"e_id":"CatherineConnolly","href":"/ie/oireachtas/member/id/Catherine-Connolly.D.2016-10-03","member_code":"Catherine-Connolly.D.2016-10-03","show_as":"Catherine Connolly"},{"e_id":"CathyBennett","href":"/ie/oireachtas/member/id/Cathy-Bennett.D.2024-11-29","member_code":"Cathy-Bennett.D.2024-11-29","show_as":"Cathy Bennett"},{"e_id":"CharlesWard","href":"/ie/oireachtas/member/id/Charles-Ward.D.2024-11-29","member_code":"Charles-Ward.D.2024-11-29","show_as":"Charles Ward"}],"root_tag":"akomaNtoso","section_tag_candidates":[{"attrs":{"eId":"dbsect_1","name":"prelude"},"tag":"debateSection"},{"attrs":{"eId":"dbsect_2","name":"debate"},"tag":"debateSection"},{"attrs":{"eId":"dbsect_3","name":"division"},"tag":"debateSection"},{"attrs":{"eId":"dbsect_4","name":"ta"},"tag":"debateSection"},{"attrs":{"eId":"dbsect_5","name":"nil"},"tag":"debateSection"},{"attrs":{"eId":"dbsect_6","name":"staon"},"tag":"debateSection"},{"attrs":{"eId":"dbsect_7","name":"debate"},"tag":"debateSection"},{"attrs":{"eId":"dbsect_8","name":"division"},"tag":"debateSection"},{"attrs":{"eId":"dbsect_9","name":"ta"},"tag":"debateSection"},{"attrs":{"eId":"dbsect_10","name":"nil"},"tag":"debateSection"},{"attrs":{"eId":"dbsect_11","name":"staon"},"tag":"debateSection"},{"attrs":{"eId":"dbsect_12","name":"debate"},"tag":"debateSection"},{"attrs":{"eId":"dbsect_13","name":"debate"},"tag":"debateSection"},{"attrs":{"eId":"dbsect_14","name":"division"},"tag":"debateSection"},{"attrs":{"eId":"dbsect_15","name":"ta"},"tag":"debateSection"},{"attrs":{"eId":"dbsect_16","name":"nil"},"tag":"debateSection"},{"attrs":{"eId":"dbsect_17","name":"staon"},"tag":"debateSection"},{"attrs":{"eId":"dbsect_18","name":"motion"},"tag":"debateSection"},{"attrs":{"eId":"dbsect_19","name":"motion"},"tag":"debateSection"}],"speech_tag_candidates":[{"attrs":{"by":"#VeronaMurphy","eId":"spk_1"},"speaker_member_code":"Verona-Murphy.D.2020-02-08","tag":"speech","text_prefix":"As we reconvene this morning to discharge the functions that we have been constitutionally mandated by our constituents to perform, we have a duty to the people who have elected us"},{"attrs":{"as":"#Minister_of_State_at_the_Department_of_the_Taoiseach","by":"#HildegardeNaughton","eId":"spk_2"},"speaker_member_code":"Hildegarde-Naughton.S.2013-07-19","tag":"speech","text_prefix":"I thank the Ceann Comhairle. I would like to update Members of the House that the Government recognises that there is an ambiguity in Standing Orders which requires clarification i"},{"attrs":{"by":"#VeronaMurphy","eId":"spk_3"},"speaker_member_code":"Verona-Murphy.D.2020-02-08","tag":"speech","text_prefix":"The Chief Whip might move now to the proposal for today's business."},{"attrs":{"as":"#Minister_of_State_at_the_Department_of_the_Taoiseach","by":"#HildegardeNaughton","eId":"spk_4"},"speaker_member_code":"Hildegarde-Naughton.S.2013-07-19","tag":"speech","text_prefix":"I thank the Ceann Comhairle. It is proposed that the following arrangements shall apply in relation to the business to be taken today: - the proceedings on the nominations for Taoi"},{"attrs":{"by":"#VeronaMurphy","eId":"spk_5"},"speaker_member_code":"Verona-Murphy.D.2020-02-08","tag":"speech","text_prefix":"I must now put the question on the Government Chief Whip's business proposal. Is the proposal agreed to?"},{"attrs":{"by":"#MaryLouMcDonald","eId":"spk_6"},"speaker_member_code":"Mary-Lou-McDonald.D.2011-03-09","tag":"speech","text_prefix":"It is not agreed. I want to raise again the issue of suspending the House for two weeks. It has been quite some time since the election. We all know that there are huge challenges "},{"attrs":{"by":"#VeronaMurphy","eId":"spk_7"},"speaker_member_code":"Verona-Murphy.D.2020-02-08","tag":"speech","text_prefix":"Thank you, Deputy."},{"attrs":{"by":"#MaryLouMcDonald","eId":"spk_8"},"speaker_member_code":"Mary-Lou-McDonald.D.2011-03-09","tag":"speech","text_prefix":"I do welcome the fact the Government has now, finally, acknowledged that there has to be a differentiation between Government and Opposition-----"},{"attrs":{"by":"#","eId":"spk_9"},"speaker_member_code":null,"tag":"speech","text_prefix":"Hear, hear."},{"attrs":{"by":"#MaryLouMcDonald","eId":"spk_10"},"speaker_member_code":"Mary-Lou-McDonald.D.2011-03-09","tag":"speech","text_prefix":"-----and that no TD can be in government and in opposition at the same time. I would further say that this is not a temporary arrangement for today. There has to be an explicit und"},{"attrs":{"by":"#VeronaMurphy","eId":"spk_11"},"speaker_member_code":"Verona-Murphy.D.2020-02-08","tag":"speech","text_prefix":"I call Deputy Ivana Bacik."},{"attrs":{"by":"#IvanaBacik","eId":"spk_12"},"speaker_member_code":"Ivana-Bacik.S.2007-07-23","tag":"speech","text_prefix":"A Cheann Comhairle, I welcome your ruling this morning. I welcome the statement by the Government Chief Whip this morning and, in particular, the acknowledgement by the Government "},{"attrs":{"by":"#VeronaMurphy","eId":"spk_13"},"speaker_member_code":"Verona-Murphy.D.2020-02-08","tag":"speech","text_prefix":"I call Deputy Cian O’Callaghan of the Social Democrats."},{"attrs":{"by":"#CianOCallaghan","eId":"spk_14"},"speaker_member_code":"Cian-O'Callaghan.D.2020-02-08","tag":"speech","text_prefix":"A Cheann Comhairle, I thank you for the work you have done in helping to bring this to a resolution for today. I also welcome the statement from the Government Chief Whip and the e"},{"attrs":{"by":"#VeronaMurphy","eId":"spk_15"},"speaker_member_code":"Verona-Murphy.D.2020-02-08","tag":"speech","text_prefix":"From the Independents and Small Parties Technical Group, I call Deputy Richard Boyd Barrett."},{"attrs":{"by":"#RichardBoydBarrett","eId":"spk_16"},"speaker_member_code":"Richard-Boyd-Barrett.D.2011-03-09","tag":"speech","text_prefix":"A Cheann Comhairle, I thank you for your efforts overnight to try to resolve this issue. We want to state for the record that we were not in any way trying to obstruct the nominati"},{"attrs":{"by":"#VeronaMurphy","eId":"spk_17"},"speaker_member_code":"Verona-Murphy.D.2020-02-08","tag":"speech","text_prefix":"This is the Order of Business."},{"attrs":{"by":"#RichardBoydBarrett","eId":"spk_18"},"speaker_member_code":"Richard-Boyd-Barrett.D.2011-03-09","tag":"speech","text_prefix":"However, we continue our opposition to the decision to suspend the Dáil for another two weeks. There are too many pressing issues for people in this country and we will be opposing"},{"attrs":{"by":"#VeronaMurphy","eId":"spk_19"},"speaker_member_code":"Verona-Murphy.D.2020-02-08","tag":"speech","text_prefix":"I call Deputy Michael Collins of the Independent Technical Group."},{"attrs":{"by":"#MichaelCollins2016","eId":"spk_20"},"speaker_member_code":"Michael-Collins.D.2016-10-03","tag":"speech","text_prefix":"Like others, a Cheann Comhairle, I thank you for resolving the situation that we have had, which has now been going on for seven days. The very democracy of the Irish Republic was "}],"tag_counts":{"FRBRExpression":1,"FRBRManifestation":1,"FRBRWork":1,"FRBRauthor":3,"FRBRcountry":1,"FRBRdate":3,"FRBRlanguage":1,"FRBRname":1,"FRBRthis":3,"FRBRuri":3,"TLCConcept":5,"TLCPerson":173,"TLCRole":2,"akomaNtoso":1,"analysis":1,"block":12,"count":9,"debate":1,"debateBody":1,"debateSection":19,"docDate":2,"docNumber":2,"docProponent":2,"docStatus":4,"docTitle":2,"from":132,"heading":6,"i":16,"identification":1,"meta":1,"p":911,"parliamentary":1,"person":515,"preface":1,"quantity":9,"recordedTime":138,"references":1,"speech":132,"summary":26,"voting":3}},{"debate_id":"https://data.oireachtas.ie/akn/ie/debateRecord/dail/2025-01-22/debate/main","person_reference_count":135,"person_reference_samples":[{"e_id":"AengusOSnodaighSF","href":"/ie/oireachtas/member/id/Aengus-Ó-Snodaigh.D.2002-06-06","member_code":"Aengus-Ó-Snodaigh.D.2002-06-06","show_as":"Aengus Ó Snodaigh"},{"e_id":"AidanFarrelly","href":"/ie/oireachtas/member/id/Aidan-Farrelly.D.2024-11-29","member_code":"Aidan-Farrelly.D.2024-11-29","show_as":"Aidan Farrelly"},{"e_id":"AindriasMoynihan","href":"/ie/oireachtas/member/id/Aindrias-Moynihan.D.2016-10-03","member_code":"Aindrias-Moynihan.D.2016-10-03","show_as":"Aindrias Moynihan"},{"e_id":"AlanDillon","href":"/ie/oireachtas/member/id/Alan-Dillon.D.2020-02-08","member_code":"Alan-Dillon.D.2020-02-08","show_as":"Alan Dillon"},{"e_id":"AlanKelly","href":"/ie/oireachtas/member/id/Alan-Kelly.S.2007-07-23","member_code":"Alan-Kelly.S.2007-07-23","show_as":"Alan Kelly"},{"e_id":"AlbertDolan","href":"/ie/oireachtas/member/id/Albert-Dolan.D.2024-11-29","member_code":"Albert-Dolan.D.2024-11-29","show_as":"Albert Dolan"},{"e_id":"AnneRabbitte","href":"/ie/oireachtas/member/id/Anne-Rabbitte.D.2016-10-03","member_code":"Anne-Rabbitte.D.2016-10-03","show_as":"Anne Rabbitte"},{"e_id":"BarryWard","href":"/ie/oireachtas/member/id/Barry-Ward.S.2020-03-30","member_code":"Barry-Ward.S.2020-03-30","show_as":"Barry Ward"},{"e_id":"BrendanSmith","href":"/ie/oireachtas/member/id/Brendan-Smith.D.1992-12-14","member_code":"Brendan-Smith.D.1992-12-14","show_as":"Brendan Smith"},{"e_id":"BrianBrennan","href":"/ie/oireachtas/member/id/Brian-Brennan.D.2024-11-29","member_code":"Brian-Brennan.D.2024-11-29","show_as":"Brian Brennan"},{"e_id":"BrianStanley","href":"/ie/oireachtas/member/id/Brian-Stanley.D.2011-03-09","member_code":"Brian-Stanley.D.2011-03-09","show_as":"Brian Stanley"},{"e_id":"CarolNolan","href":"/ie/oireachtas/member/id/Carol-Nolan.D.2016-10-03","member_code":"Carol-Nolan.D.2016-10-03","show_as":"Carol Nolan"},{"e_id":"CathalCrowe","href":"/ie/oireachtas/member/id/Cathal-Crowe.D.2020-02-08","member_code":"Cathal-Crowe.D.2020-02-08","show_as":"Cathal Crowe"},{"e_id":"CatherineConnolly","href":"/ie/oireachtas/member/id/Catherine-Connolly.D.2016-10-03","member_code":"Catherine-Connolly.D.2016-10-03","show_as":"Catherine Connolly"},{"e_id":"CatherineMartin","href":"/ie/oireachtas/member/id/Catherine-Martin.D.2016-10-03","member_code":"Catherine-Martin.D.2016-10-03","show_as":"Catherine Martin"},{"e_id":"CharlesWard","href":"/ie/oireachtas/member/id/Charles-Ward.D.2024-11-29","member_code":"Charles-Ward.D.2024-11-29","show_as":"Charles Ward"},{"e_id":"CharlieMcConalogue","href":"/ie/oireachtas/member/id/Charlie-McConalogue.D.2011-03-09","member_code":"Charlie-McConalogue.D.2011-03-09","show_as":"Charlie McConalogue"},{"e_id":"ChristopherOsullivan","href":"/ie/oireachtas/member/id/Christopher-O'Sullivan.D.2020-02-08","member_code":"Christopher-O'Sullivan.D.2020-02-08","show_as":"Christopher O'Sullivan"},{"e_id":"CianOCallaghan","href":"/ie/oireachtas/member/id/Cian-O'Callaghan.D.2020-02-08","member_code":"Cian-O'Callaghan.D.2020-02-08","show_as":"Cian O'Callaghan"},{"e_id":"ClaireKerrane","href":"/ie/oireachtas/member/id/Claire-Kerrane.D.2020-02-08","member_code":"Claire-Kerrane.D.2020-02-08","show_as":"Claire Kerrane"}],"root_tag":"akomaNtoso","section_tag_candidates":[{"attrs":{"eId":"dbsect_1","name":"prelude"},"tag":"debateSection"},{"attrs":{"eId":"dbsect_2","name":"debate"},"tag":"debateSection"},{"attrs":{"eId":"dbsect_3","name":"debate"},"tag":"debateSection"}],"speech_tag_candidates":[{"attrs":{"by":"#VeronaMurphy","eId":"spk_1"},"speaker_member_code":"Verona-Murphy.D.2020-02-08","tag":"speech","text_prefix":"Before we commence the very important constitutional business of nominating a Taoiseach, I wish to advise the House of what was agreed yesterday in the Business Committee on the sp"},{"attrs":{"as":"#Minister_of_State_at_the_Department_of_the_Taoiseach","by":"#HildegardeNaughton","eId":"spk_2"},"speaker_member_code":"Hildegarde-Naughton.S.2013-07-19","tag":"speech","text_prefix":"I thank the Ceann Comhairle. It is proposed that the following arrangements shall apply to the business to be taken today: - The proceedings on the nominations for Taoiseach shall,"},{"attrs":{"by":"#EoinOBroin","eId":"spk_3"},"speaker_member_code":"Eoin-Ó-Broin.D.2016-10-03","tag":"speech","text_prefix":"That is a joke."},{"attrs":{"by":"#MaryLouMcDonald","eId":"spk_4"},"speaker_member_code":"Mary-Lou-McDonald.D.2011-03-09","tag":"speech","text_prefix":"It is ridiculous."},{"attrs":{"as":"#Minister_of_State_at_the_Department_of_the_Taoiseach","by":"#HildegardeNaughton","eId":"spk_5"},"speaker_member_code":"Hildegarde-Naughton.S.2013-07-19","tag":"speech","text_prefix":"----- - the proceedings on the motion re establishment of Select Committee on Subsidiarity (European Union Legislative Scrutiny) shall be taken as the last item of business without"},{"attrs":{"by":"#RichardBoydBarrett","eId":"spk_6"},"speaker_member_code":"Richard-Boyd-Barrett.D.2011-03-09","tag":"speech","text_prefix":"That is not agreed."},{"attrs":{"by":"#LouiseOReilly","eId":"spk_7"},"speaker_member_code":"Louise-O'Reilly.D.2016-10-03","tag":"speech","text_prefix":"It is absolutely not agreed."},{"attrs":{"by":"#VeronaMurphy","eId":"spk_8"},"speaker_member_code":"Verona-Murphy.D.2020-02-08","tag":"speech","text_prefix":"Deputies might give me a chance to ask the question. I take it that the proposal is not agreed."},{"attrs":{"by":"#RichardBoydBarrett","eId":"spk_9"},"speaker_member_code":"Richard-Boyd-Barrett.D.2011-03-09","tag":"speech","text_prefix":"It is not agreed."},{"attrs":{"by":"#VeronaMurphy","eId":"spk_10"},"speaker_member_code":"Verona-Murphy.D.2020-02-08","tag":"speech","text_prefix":"I propose we take brief statements, starting with Deputy Mary Lou McDonald."},{"attrs":{"by":"#MaryLouMcDonald","eId":"spk_11"},"speaker_member_code":"Mary-Lou-McDonald.D.2011-03-09","tag":"speech","text_prefix":"It is astonishing, after weeks and weeks of haggling among the parties that proposed to form Government over who would get which job, and how much they could increase the respectiv"},{"attrs":{"by":"#PearseDoherty","eId":"spk_12"},"speaker_member_code":"Pearse-Doherty.S.2007-07-23","tag":"speech","text_prefix":"Hear, hear."},{"attrs":{"by":"#MaryLouMcDonald","eId":"spk_13"},"speaker_member_code":"Mary-Lou-McDonald.D.2011-03-09","tag":"speech","text_prefix":"-----which, remember, are elected here by hundreds of thousands of voters to hold this Government to account and express the democratic wishes and desires of those people and commu"},{"attrs":{"by":"#PearseDoherty","eId":"spk_14"},"speaker_member_code":"Pearse-Doherty.S.2007-07-23","tag":"speech","text_prefix":"Hear, hear."},{"attrs":{"by":"#LouiseOReilly","eId":"spk_15"},"speaker_member_code":"Louise-O'Reilly.D.2016-10-03","tag":"speech","text_prefix":"Hear, hear."},{"attrs":{"by":"#VeronaMurphy","eId":"spk_16"},"speaker_member_code":"Verona-Murphy.D.2020-02-08","tag":"speech","text_prefix":"The next speaker is Deputy Duncan Smith from the Labour Party."},{"attrs":{"by":"#DuncanSmith","eId":"spk_17"},"speaker_member_code":"Duncan-Smith.D.2020-02-08","tag":"speech","text_prefix":"It needs to be said that at the Business Committee yesterday, all Opposition members registered their dissent to the arrangements and to the matter of the speaking rights for the t"},{"attrs":{"by":"#","eId":"spk_18"},"speaker_member_code":null,"tag":"speech","text_prefix":"Yes."},{"attrs":{"by":"#DuncanSmith","eId":"spk_19"},"speaker_member_code":"Duncan-Smith.D.2020-02-08","tag":"speech","text_prefix":"They are really angry about it. I would like the Ceann Comhairle to commit to a deadline as to when she will make an adjudication on the joint submission from the Opposition on thi"},{"attrs":{"by":"#","eId":"spk_20"},"speaker_member_code":null,"tag":"speech","text_prefix":"Yes."}],"tag_counts":{"FRBRExpression":1,"FRBRManifestation":1,"FRBRWork":1,"FRBRauthor":3,"FRBRcountry":1,"FRBRdate":3,"FRBRlanguage":1,"FRBRname":1,"FRBRthis":3,"FRBRuri":3,"TLCPerson":135,"TLCRole":49,"akomaNtoso":1,"block":12,"debate":1,"debateBody":1,"debateSection":3,"docDate":2,"docNumber":2,"docProponent":2,"docStatus":4,"docTitle":2,"from":225,"heading":2,"i":17,"identification":1,"meta":1,"p":254,"preface":1,"recordedTime":227,"references":1,"speech":225,"summary":31}}],"xml_downloads":[{"byte_size":276286,"debate_id":"https://data.oireachtas.ie/akn/ie/debateRecord/dail/2025-01-23/debate/main","sha256":"1e3e5b6620574e5c7f0bcd1572a1fca47e033ec36f917d632d943d81722b1f21","source_file_id":"source_file:2e3f8d29d92f6ad336f74a71","speech_rows":132,"status":"success","xml_source_key":"raw/oireachtas_unified/source_files/debate/data.oireachtas.ie-akn-ie-debateRecord-dail-2025-01-23-debate-main/source_file-2e3f8d29d92f6ad336f74a71.xml","xml_url":"https://data.oireachtas.ie/akn/ie/debateRecord/dail/2025-01-23/debate/mul@/main.xml"},{"byte_size":103413,"debate_id":"https://data.oireachtas.ie/akn/ie/debateRecord/dail/2025-01-22/debate/main","sha256":"f5e7df9972158fdecd4a51e3acca8a3232d51529b4aba5e9c98d69b1f2c2484a","source_file_id":"source_file:a7530d36b8e66d9be3c0c883","speech_rows":225,"status":"success","xml_source_key":"raw/oireachtas_unified/source_files/debate/data.oireachtas.ie-akn-ie-debateRecord-dail-2025-01-22-debate-main/source_file-a7530d36b8e66d9be3c0c883.xml","xml_url":"https://data.oireachtas.ie/akn/ie/debateRecord/dail/2025-01-22/debate/mul@/main.xml"}]}
